# SENDGRID_API_KEY: Recommended to send emails automatically.
# Get a free API key from SendGrid (sendgrid.com) and set it in the AI Studio Secrets panel.
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY_HERE

# SENDER_EMAIL: Verified sender email address in your SendGrid dashboard.
SENDGRID_SENDER_EMAIL=noreply@aistudio-media-sender.com

# SENDER_NAME: Human-readable sender name.
SENDGRID_SENDER_NAME=Media Auto-Sender
